{
  "name": "cloth-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:tma": "npm run dev -w apps/tma -- --host 0.0.0.0 --port 5182",
    "dev:dashboard": "npm run dev -w apps/dashboard -- --host 0.0.0.0 --port 5190",
    "dev:landing": "npm run dev -w apps/landing -- --host 0.0.0.0 --port 5191",
    "build:tma": "npm run build -w apps/tma",
    "build:dashboard": "npm run build -w apps/dashboard",
    "build:landing": "npm run build -w apps/landing",
    "preview:tma": "npm run preview -w apps/tma",
    "preview:dashboard": "npm run preview -w apps/dashboard",
    "preview:landing": "npm run preview -w apps/landing"
  }
}

